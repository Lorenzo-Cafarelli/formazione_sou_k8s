// File: Step2/Jenkinsfile (Struttura corretta per la Diagnosi)
pipeline {
    // Definizione del nodo su cui verrà eseguito il lavoro
    agent { 
        // L'agente deve avere l'etichetta 'docker-agent' (quello che hai installato)
        label 'docker-agent' 
    } 

    // Variabili d'ambiente per il processo
    environment {
        // ID della credenziale Jenkins per Docker Hub (configurato in 'Manage Credentials')
        DOCKERHUB_CREDENTIALS = credentials('docker-creds') 
        
        // ⚠️ SOSTITUISCI CON IL TUO UTENTE/NOME IMMAGINE E REGISTRY
        DOCKER_IMAGE_NAME = "lorenzocafarelli/flask-hello-world"
        TAG = "latest"
        
        // Comando CLI: Inserisci qui il percorso che pensi sia corretto
        CLI = '/usr/bin/podman' 
    }

    stages { // <-- IL CONTENITORE DEVE ESSERE QUI
        
        stage('DIAGNOSI: Ricerca del Percorso') {
            steps {
                echo "=========================================================="
                echo "DIAGNOSI: RICERCA DEL PERCORSO DI PODMAN"
                echo "=========================================================="
                
                // Esegue il comando di ricerca e indirizza gli errori a /dev/null
                sh "find / -name podman 2>/dev/null"
                
                echo "Esecuzione completata. Cerca i percorsi nell'output qui sopra."
            }
        }
// Rimuovi o commenta gli stage successivi per evitare fallimenti

