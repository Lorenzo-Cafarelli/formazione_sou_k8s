/*
 * Pipeline dichiarativa di Jenkins (Versione Corretta)
 * Eseguita dall'agente personalizzato che ha 'podman' installato.
 */
pipeline {
    // L'agente è 'docker-agent' (il nostro container personalizzato)
    agent { 
        label 'docker-agent' 
    } 

    environment {
        // ⚠️ SOSTITUISCI CON IL TUO UTENTE/NOME IMMAGINE
        DOCKER_IMAGE_NAME = "lorenzocafarelli/flask-hello-world"
        TAG = "build-${BUILD_NUMBER}" // Usa un tag univoco
        
        // Non serve 'sudo' o 'withEnv'
        // L'agente ha 'podman' nel suo PATH.
        CLI = 'podman' 
    }

    stages {
        stage('Preparazione e Build Immagine') {
            steps {
                echo "FASE 1: Avvio Build (con Podman-in-Podman)"
                echo "Immagine target: ${DOCKER_IMAGE_NAME}:${TAG}"
                
                // Esegue il build. Funzionerà perché l'agente 
                // ha 'podman' e accesso al socket.
                sh "${CLI} build -t ${DOCKER_IMAGE_NAME}:${TAG} ."
                
                echo "✅ Build immagine completato con successo."
            }
        }
        
        stage('Login e Push su Docker Hub') {
            steps {
                // Usa le credenziali Jenkins (ID 'docker-creds')
                withCredentials([usernamePassword(
                    credentialsId: 'docker-creds', 
                    passwordVariable: '49722184cd0b40f9814da903f3522f1d', 
                    usernameVariable: 'admin'
                )]) {
                    
                    echo "FASE 2: Esecuzione del Login e del Push."
                    echo "Tentativo di login per l'utente ${DOCKER_USER}..."
                    
                    // Login
                    sh "${CLI} login -u ${DOCKER_USER} -p ${DOCKER_PASSWORD} docker.io"

                    echo "Login completato. Inizio Push dell'immagine."
                    
                    // Push
                    sh "${CLI} push ${DOCKER_IMAGE_NAME}:${TAG}"
                    
                    echo "✅ Push completato su Docker Hub."
                    
                    // Logout
                    sh "${CLI} logout docker.io"
                    echo "Logout effettuato."
                }
            }
        }
    }
}
