/*
 * Pipeline dichiarativa di Jenkins (Versione con Installazione)
 *
 * Tenta di installare Ansible da solo prima di usarlo.
 * NOTA: Questo richiede che l'utente 'jenkins' sull'agente
 * abbia i permessi di SUDO per eseguire 'dnf'.
 */
pipeline {
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    agent any

    environment {
        IMAGE_NAME = 'flask-hello-world'
        IMAGE_TAG = "build-${BUILD_NUMBER}" 
    }

    stages {

        // --- STAGE 1: INSTALLA LE DIPENDENZE ---
        stage('Install Dependencies') {
            steps {
                echo "Tentativo di installare Ansible e dipendenze sull'agente..."
                sh '''
                    echo "Installazione di EPEL-Release..."
                    sudo dnf install epel-release -y
                    
                    echo "Installazione di Ansible-Core..."
                    sudo dnf install ansible-core -y
                    
                    echo "Installazione di Python PIP..."
                    sudo dnf install python3-pip -y
                    
                    echo "Installazione libreria Python per Docker..."
                    sudo pip3 install docker
                    
                    echo "Installazione collection Ansible per Docker..."
                    ansible-galaxy collection install community.docker
                    
                    echo "Verifica installazione..."
                    which ansible-playbook
                '''
            }
        }
        
        // --- STAGE 2: Build dell'immagine Docker via Ansible ---
        stage('Build Docker Image with Ansible') {
            steps {
                echo "Avvio il playbook Ansible per costruire l'immagine: ${IMAGE_NAME}:${IMAGE_TAG}"
                
                sh """
                    ansible-playbook build-playbook.yml \
                        -e "image_name=${IMAGE_NAME}" \
                        -e "image_tag=${IMAGE_TAG}"
                """
                
                echo "Build dell'immagine Docker completata con successo."
            }
        }
    }
    
    // Azioni da eseguire al termine della pipeline
    post {
        success {
            echo "Pipeline flask-app-example-build completata con successo."
        }
        failure {
            echo "Pipeline flask-app-example-build fallita."
        }
    }
}

